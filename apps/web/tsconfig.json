{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@g-agent-template/contracts": ["../../packages/contracts/src/index.ts"],
      "@g-agent-template/contracts/*": ["../../packages/contracts/src/*"],
      "@g-agent-template/utils": ["../../packages/utils/src/index.ts"],
      "@g-agent-template/utils/*": ["../../packages/utils/src/*"]
    },
    "noEmit": true
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
