{
  "name": "@g-agent-template/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "pnpm --filter @g-agent-template/shared build && pnpm --filter @g-agent-template/database db:generate",
    "build": "nest build",
    "predev": "pnpm --filter @g-agent-template/shared build && pnpm --filter @g-agent-template/database db:generate",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:prod": "node dist/main.js",
    "lint": "oxlint",
    "pretypecheck": "pnpm --filter @g-agent-template/shared build && pnpm --filter @g-agent-template/database db:generate",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@g-agent-template/shared": "workspace:*",
    "@g-agent-template/database": "workspace:*",
    "@nestjs/common": "^10.4.7",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.7",
    "@nestjs/platform-express": "^10.4.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.7",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.7",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.0",
    "dotenv": "^17.3.1",
    "jest": "^29.7.0",
    "oxlint": "^0.16.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
